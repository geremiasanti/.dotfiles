prefix_rule(pattern=["/bin/bash", "-lc", "bin/rails runner 'require \"google/apis/sheets_v4\"; spreadsheet_id = \"19Dz8upoP7Ak-SVBl-PqA-BsdzMTO-Uut878PA-ZSvHk\"; start_date = Date.new(2026,3,9); end_date = Date.new(2026,3,21); game_name_by_id = Game.pluck(:id, :name).to_h; rows = BusinessStat.where(stats_date: start_date..end_date).order(:stats_date).pluck(:stats_date, :daily_sale_amount_cents_by_game).map { |date, by_game| [date.to_date, by_game || {}] }; daily_by_game = Hash.new { |h, k| h[k] = [] }; rows.each do |date, by_game| by_game.each { |game_id, cents| daily_by_game[game_name_by_id[game_id.to_i] || game_id.to_s] << [date, cents.to_i / 100.0] } end; writer = GoogleSpreadsheetWriterService.new(spreadsheet_id); service = writer.instance_variable_get(:@service); daily_by_game.sort.each do |game_name, series| sheet = writer.find_or_create_sheet_by_title(game_name); values = [[\"date\", \"sales\", \"delta_vs_previous_day\"]]; prev = nil; series.sort_by(&:first).each do |date, eur| delta = prev.nil? ? nil : (eur - prev).round(2); values << [date.iso8601, eur.round(2), delta]; prev = eur; end; range = \"\\'#{sheet.properties.title}\\'!A:C\"; service.clear_values(spreadsheet_id, range, Google::Apis::SheetsV4::ClearValuesRequest.new); body = Google::Apis::SheetsV4::ValueRange.new(values: values); service.update_spreadsheet_value(spreadsheet_id, range, body, value_input_option: \"RAW\"); puts [\"updated\", game_name, values.size - 1].join(\"\\t\"); end'"], decision="allow")
